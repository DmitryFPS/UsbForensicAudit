<Window x:Class="UsbForensicAudit.ActiveDevicesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сейчас подключено USB/Type-C"
        Height="480"
        Width="1100"
        MinHeight="360"
        MinWidth="820"
        FontFamily="Segoe UI"
        Background="#07111F">
    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#081320"/>
            <Setter Property="Foreground" Value="#D9E8F5"/>
            <Setter Property="BorderBrush" Value="#1F3B59"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1A2F49"/>
            <Setter Property="VerticalGridLinesBrush" Value="#1A2F49"/>
            <Setter Property="RowBackground" Value="#0B1728"/>
            <Setter Property="AlternatingRowBackground" Value="#0E1D30"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#122840"/>
            <Setter Property="Foreground" Value="#BFE7FF"/>
            <Setter Property="BorderBrush" Value="#1F3B59"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,7"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Foreground" Value="#D9E8F5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#0B1728" BorderBrush="#38BDF8" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Ellipse Width="42" Height="42" Fill="#0F2B45" Stroke="#38D996" StrokeThickness="1.5"/>
                <Path Grid.Column="0" Stroke="#38D996" StrokeThickness="2.2" Data="M12,21 L30,21 M21,12 L21,30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                    <TextBlock Text="Сейчас подключено USB / Type-C" Foreground="#E5F2FF" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Показывает только устройства, которые подключены прямо сейчас. После отключения строка исчезает, но история остаётся во вкладке «USB устройства»."
                               Foreground="#8EA7BF"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="1"
                  x:Name="ActiveDevicesGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding ActiveDevices}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Когда заметили" Binding="{Binding ConnectedAtText}" Width="185"/>
                <DataGridTextColumn Header="Что подключено" Binding="{Binding DeviceName}" Width="290"/>
                <DataGridTextColumn Header="Расположение" Binding="{Binding LocationText}" Width="170"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding ManufacturerText}" Width="130"/>
                <DataGridTextColumn Header="Модель" Binding="{Binding ModelText}" Width="150"/>
                <DataGridTextColumn Header="VID / PID" Binding="{Binding VidPidText}" Width="115"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" Width="220"/>
                <DataGridTextColumn Header="Системный ID" Binding="{Binding DeviceId}" Width="360"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
