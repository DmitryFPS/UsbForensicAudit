<Window x:Class="UsbForensicAudit.DeviceDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сведения об USB-устройстве"
        Width="620"
        Height="680"
        MinHeight="480"
        MaxHeight="720"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Background="#07111F">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8EA7BF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FieldValue" TargetType="TextBox">
            <Setter Property="Foreground" Value="#E5F2FF"/>
            <Setter Property="Background" Value="#101F33"/>
            <Setter Property="BorderBrush" Value="#1F3B59"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#E5F2FF"/>
            <Setter Property="Background" Value="#14532D"/>
            <Setter Property="BorderBrush" Value="#38D996"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="22,9"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Margin="18"
            Padding="20"
            Background="#0B1728"
            BorderBrush="#1F3B59"
            BorderThickness="1"
            CornerRadius="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Сведения об устройстве"
                       Foreground="#38BDF8"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="0,0,0,18"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          Margin="0,0,-8,0"
                          Padding="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Имя устройства" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding DisplayName, Mode=OneWay}" Style="{StaticResource FieldValue}"/>

                    <TextBlock Text="Transport / connection / classification" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding ClassificationDisplayText, Mode=OneWay}" Style="{StaticResource FieldValue}"/>

                    <TextBlock Text="Evidence классификации" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding ClassificationEvidenceText, Mode=OneWay}" Style="{StaticResource FieldValue}"/>

                    <TextBlock Text="Когда подключали" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FirstConnectedText, Mode=OneWay}" Style="{StaticResource FieldValue}"/>

                    <TextBlock Text="Последняя активность" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding LastSeenText, Mode=OneWay}" Style="{StaticResource FieldValue}"/>

                    <TextBlock Text="Модель" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding ModelText, Mode=OneWay}" Style="{StaticResource FieldValue}"/>

                    <TextBlock Text="PID / VID" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding VidPidText, Mode=OneWay}" Style="{StaticResource FieldValue}"/>

                    <TextBlock Text="Серийный номер" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding SerialText, Mode=OneWay}" Style="{StaticResource FieldValue}"/>
                </StackPanel>
            </ScrollViewer>

            <Button Content="Закрыть"
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0"
                    IsDefault="True"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </Grid>
    </Border>
</Window>
