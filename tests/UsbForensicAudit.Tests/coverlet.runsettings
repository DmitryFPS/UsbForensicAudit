<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Threshold>90</Threshold>
          <ThresholdType>line</ThresholdType>
          <ThresholdStat>total</ThresholdStat>
          <ExcludeByFile>
            **/MainWindow.xaml.cs,
            **/CellExplanationToolTipConverter.cs,
            **/ActiveDevicesWindow*,
            **/App.xaml.cs,
            **/*Collector.cs,
            **/ReportService.cs,
            **/*Pdf*.cs,
            **/ForensicReportBuilder.cs,
            **/ManualPdfGenerator.cs,
            **/ProcmonBootstrap.cs,
            **/ProcmonTraceService.cs,
            **/ProcmonTraceRunner.cs,
            **/ExternalUtilityWindowAutomation.cs,
            **/ExternalUtilityRegistrySourceTracer.cs,
            **/Win32ListViewUiAutomationReader.cs,
            **/Win32ListViewClipboardReader.cs,
            **/WmiUsbMonitor.cs,
            **/WmiConnectedDeviceProbe.cs,
            **/DeviceChangeNotifier.cs,
            **/LiveUsbSnapshotService.cs,
            **/LiveDeviceMetadataReader.cs,
            **/RunningExternalUtilityScanner.cs,
            **/OfflineHiveCollector.cs,
            **/AdminHelper.cs,
            **/AppLog.cs,
            **/DarkWindowChrome.cs,
            **/DataGridAutoSize.cs,
            **/PdfFontHelper.cs,
            **/AppBranding.cs,
            **/ExternalUtilityCaptureRunner.cs,
            **/ExternalUtilityWindowCaptureService.cs,
            **/UsbRegistryCollector.cs,
            **/EndpointProtectionEnvironment.cs,
            **/LiveDeviceMerger.cs,
            **/OsInstallInfo.cs,
            **/RegistryKeyTimestamps.cs,
            **/ArtifactStringExtractor.cs,
            **/Win32WindowHelper.cs,
            **/Win32Message.cs,
            **/AuthenticodeTrust.cs,
            **/LiveUsbDevice.cs,
            **/Win32ListViewReader.cs,
            **/AppPaths.cs,
            **/*.xaml,
            **/obj/**,
            **/*.g.cs
          </ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
